DB_USERNAME=postgres
DB_PASSWORD=Doom@ternal7714

# ── JWT ────────────────────────────────────────────────────────────────────
# This is the LOCAL DEV secret. Replace with your own for production.
# Must be Base64-encoded and decode to at least 32 bytes.
# Generate a new one with:  openssl rand -base64 64
JWT_SECRET=dG9rZW5zZWNyZXRmb3Jkb29tcGxhdGZvcm1kZXZlbG9wbWVudHVzZW9ubHlub3Rmb3Jwcm9kdWN0aW9uMTIzNDU2Nzg=

